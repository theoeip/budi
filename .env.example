# ============================================================
# BUDI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# WARNING: Never commit .env files to version control.
# WARNING: Never share real secrets.

# ============================================================
# APPLICATION
# ============================================================
VITE_APP_NAME=BUDI
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# ============================================================
# SUPABASE
# ============================================================
# Get these from your Supabase project dashboard:
#   Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — ONLY used in server-side / CI contexts
# NEVER expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# FEATURE FLAGS
# ============================================================
# Set to "true" to enable the module
VITE_FEATURE_FINANCE=true
VITE_FEATURE_ACADEMIC=false
VITE_FEATURE_LIBRARY=false
VITE_FEATURE_ATTENDANCE=false
VITE_FEATURE_INVENTORY=false
VITE_FEATURE_PAYROLL=false
VITE_FEATURE_STUDENT=false
VITE_FEATURE_TEACHER=false
VITE_FEATURE_PPDB=false

# ============================================================
# MONITORING (Optional)
# ============================================================
# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Analytics ID (e.g., Google Analytics, Plausible)
VITE_ANALYTICS_ID=

# ============================================================
# API
# ============================================================
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=3

